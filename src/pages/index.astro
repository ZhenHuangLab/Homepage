---
import MainLayout from "~/layouts/MainLayout.astro";

import { Separator } from "~/components/ui";
import Starbg from "~/components/starbg.astro";
import About from "~/components/About.tsx";
import Projects from "~/components/Projects.tsx";
import Stacks from "~/components/Stacks.tsx";
import Socials from "~/components/Socials.tsx";
import DevelopedBy from "~/components/DevelopedBy.tsx";
---

<MainLayout>
  <main class="container p-3 mx-auto max-w-screen-sm min-h-dvh">
    <Starbg />
    <About client:idle />

    <Separator className="my-8" />
    
    <Stacks client:idle />

    <div class="h-10"></div>

    <Projects client:idle />

    <div class="h-10"></div>

    <Socials client:idle />

    <Separator className="my-8" />

    <DevelopedBy />
  </main>
</MainLayout>

<style>
  :global(#starfield) {
    position: fixed; /* 或 absolute，取决于你的具体需求 */
    top: 0;
    left: 0;
    width: 100vw;
    /* 用 lvh（大视口高度）固定高度：移动端地址栏收起/展开不会改变它，
       避免容器 resize 导致星空重置闪烁 */
    height: 100vh;
    height: 100lvh;
    z-index: -1; /* 确保它在其他内容之后 */
  }
  /* boxes pattern */
  body {
    z-index: 1;
    position: relative;
    background-color: rgb(var(--neutral-1));
    background-image: linear-gradient(rgb(var(--neutral-2)) 1px, transparent 1px),
      linear-gradient(to right, rgb(var(--neutral-2)) 1px, rgb(var(--neutral-1)) 1px);
    background-size: 40px 40px;
  }

  body::after {
    z-index: -1;
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    background-image: linear-gradient(to bottom, transparent, rgb(var(--neutral-1)));
  }
</style>
